{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "kuru",
  "version": "1.0.0",
  "identifier": "com.slime.kuru",
  "build": {
    "beforeDevCommand": "next dev",
    "devUrl": "http://localhost:3000",
    "beforeBuildCommand": "next build",
    "frontendDist": "../out"
  },
  "app": {
    "windows": [
      {
        "title": "kuru",
        "width": 140,
        "height": 150,
        "decorations": false,
        "transparent": true,
        "shadow": false,
        "alwaysOnTop": true,
        "resizable": false,
        "fullscreen": false,
        "maximizable": false,
        "minimizable": false,
        "closable": true,
        "skipTaskbar": true,
        "visible": true,
        "focus": true,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
